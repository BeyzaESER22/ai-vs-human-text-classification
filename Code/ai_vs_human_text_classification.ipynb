    i += 1


#This graph plot the number of 150<= text number <= 200
plt.subplot(2, 3, 2)
plt.hist(DFFiltered['word_count'], bins = 30, alpha = 0.5, color = 'skyblue', edgecolor = 'black')
plt.axvline(150, color = 'red', linestyle ='dashed', alpha = 0.8, label = '150 words')
